<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

</beans>
<hibernate-configuration>
<session-factory>
    <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
    <property name="hibernate.connection.url">jdbc:postgresql://localhost:15432/postgres</property>
    <property name="hibernate.connection.username">postgres</property>
    <property name="hibernate.connection.password">2DAMAD</property>
    <property name="hibernate.default_schema">public</property>
    <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>
    <property name="hibernate.c3p0.min_size">5</property>
    <property name="hibernate.c3p0.max_size">20</property>
    <property name="hibernate.c3p0.timeout">1800</property>
    <property name="hibernate.c3p0.max_statements">50</property>
    <property name="connection.provider_class">org.hibernate.c3p0.internal.C3P0ConnectionProvider</property>
    <property name="show_sql">true</property>

    <mapping class="org.educa.entity.ClienteEntity"/>
    <mapping class="org.educa.entity.AlquilerEntity"/>
    <mapping class="org.educa.entity.VehiculoEntity"/>
    <mapping class="org.educa.entity.CategoriaEntity"/>
    <mapping class="org.educa.entity.SucursalEntity"/>
    <mapping class="org.educa.entity.DireccionEntity"/>
    <mapping class="org.educa.entity.CombustibleEntity"/>
    <mapping class="org.educa.entity.EquipamientoEntity"/>
    <mapping class="org.educa.entity.SeguroEntity"/>
</session-factory>
</hibernate-configuration>